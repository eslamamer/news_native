<?php $news_list = search('news', 
                    'join categories on news.cat_id = categories.id
                     join users      on news.user_id= users.id where news.id='.request('news_id'),
                    'news.id,
                     news.title,
                     news.description,
                     news.content,
                     news.created_at,
                     news.updated_at,
                     users.id          as userid,
                     users.name        as auther,
                     categories.name   as catname,
                     categories.id     as catid');
      $news = mysqli_fetch_assoc($news_list['query']);
      if(empty($news)){
        redirect('/');
      }
      render('front.layout.header', ['title' => trans('news.'.$news['title'])]);
?>
<div class="col-mb-2">
  <div class="col-md-12">
    <article class="blog-post">
      <h2 class="display-5 link-body-emphasis mb-1"><?= $news['title']?></h2>
      <p class="blog-post-meta">
          <?= $news['updated_at']?>
        <a href="<?= url('users/user?id='.$news['userid'])?>">
          <?= $news['auther']?>
        </a>
      </p> 
      <div class="col-auto d-none d-lg-block">
        <?php
          if(!empty($news['image'])){
            $img = url('/storage'.$news['image']);
          }elseif(!empty($news['icon'])){
            $img = url('/storage'.$news['icon']);
          }else{
            $img = url('/assets/images/icon.png');
          }
        ?>
        <img style="width:200px; height:100%;" src="<?= $img?>" alt="icon">
      </div>
      <p><?= $news['content']?></p>   
    </article>
  </div>
  <hr>
  <div class="col-md-12">
      <?= render('front.categories.comments')?>
  </div>
</div>
<?= render('front.layout.footer')?>